  "query": "\n            SELECT\n                id,\n                trigger,\n                trigger_ref,\n                config,\n                payload,\n                source,\n                source_ref,\n                created,\n                updated,\n                rule,\n                rule_ref\n            FROM event\n            WHERE trigger_ref = $1\n            ORDER BY created DESC\n            LIMIT $2\n            ",
