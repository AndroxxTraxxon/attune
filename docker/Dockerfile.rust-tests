# Dockerfile for running Rust integration tests against a live database
#
# Compiles the workspace in test mode and runs all #[ignore]'d tests.
# These tests exercise repository layer, API endpoints, and execution logic
# directly in Rust — they need a database but not the full service stack.
#
# The image keeps the source tree layout intact so CARGO_MANIFEST_DIR-relative
# path lookups (../../config.test.yaml, ../../migrations) work correctly.
#
# Usage:
#   docker compose -f docker-compose.yaml -f docker-compose.e2e.yaml \
#     run --rm rust-integration-tests [-- <cargo test args>]

ARG RUST_VERSION=1.92
ARG DEBIAN_VERSION=bookworm

FROM rust:${RUST_VERSION}-${DEBIAN_VERSION}

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    ca-certificates \
    python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Increase rustc stack size to prevent SIGSEGV
ENV RUST_MIN_STACK=67108864

# Enable SQLx offline mode (no live DB needed at compile time)
ENV SQLX_OFFLINE=true

# Copy dependency metadata first for layer caching
COPY Cargo.toml Cargo.lock ./
COPY crates/common/Cargo.toml ./crates/common/Cargo.toml
COPY crates/api/Cargo.toml ./crates/api/Cargo.toml
COPY crates/executor/Cargo.toml ./crates/executor/Cargo.toml
COPY crates/sensor/Cargo.toml ./crates/sensor/Cargo.toml
COPY crates/worker/Cargo.toml ./crates/worker/Cargo.toml
COPY crates/notifier/Cargo.toml ./crates/notifier/Cargo.toml
COPY crates/supervisor/Cargo.toml ./crates/supervisor/Cargo.toml
COPY crates/cli/Cargo.toml ./crates/cli/Cargo.toml

# Create minimal stub sources for dep resolution and fetch
RUN mkdir -p crates/common/src && echo "" > crates/common/src/lib.rs && \
    mkdir -p crates/api/src && echo "fn main(){}" > crates/api/src/main.rs && \
    mkdir -p crates/executor/src && echo "fn main(){}" > crates/executor/src/main.rs && \
    mkdir -p crates/executor/benches && echo "fn main(){}" > crates/executor/benches/context_clone.rs && \
    mkdir -p crates/sensor/src && echo "fn main(){}" > crates/sensor/src/main.rs && \
    mkdir -p crates/worker/src && echo "fn main(){}" > crates/worker/src/main.rs && \
    echo "fn main(){}" > crates/worker/src/agent_main.rs && \
    mkdir -p crates/notifier/src && echo "fn main(){}" > crates/notifier/src/main.rs && \
    mkdir -p crates/supervisor/src && echo "fn main(){}" > crates/supervisor/src/main.rs && \
    mkdir -p crates/cli/src && echo "fn main(){}" > crates/cli/src/main.rs

# Download dependencies (cached unless Cargo.toml/Cargo.lock change)
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=shared \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=shared \
    cargo fetch

# Now copy the full source tree (needed at runtime for CARGO_MANIFEST_DIR paths)
COPY crates/ ./crates/
COPY migrations/ ./migrations/
COPY .sqlx/ ./.sqlx/
COPY config.test.yaml ./config.test.yaml

# Pre-compile test binaries (--no-run) to cache the build layer
# This way subsequent runs only need to execute, not recompile
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=shared \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=shared \
    --mount=type=cache,target=/build/target,id=rust-integration-tests,sharing=locked \
    cargo test --workspace --no-run 2>&1 | tail -30

# Copy entrypoint
COPY docker/rust-tests-entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
