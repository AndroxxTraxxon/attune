# Attune Environment Configuration
# This file is sourced by systemd service units.
# Uncomment and modify settings as needed.

# Required for production — generate unique secrets:
#   openssl rand -base64 32
# JWT_SECRET=change-me-in-production
# ENCRYPTION_KEY=change-me-in-production

# Config file location (default: /etc/attune/attune.yaml)
# ATTUNE_CONFIG=/etc/attune/attune.yaml

# Database URL override
# ATTUNE__DATABASE__URL=postgresql://attune:attune@localhost:5432/attune

# API server port
# ATTUNE__SERVER__PORT=8080

# Notifier server port
# ATTUNE__NOTIFIER__PORT=8081

# RabbitMQ URL
# ATTUNE__RABBITMQ__URL=amqp://attune:attune@localhost:5672/attune

# Log level (uses RUST_LOG syntax)
# RUST_LOG=info

# Limit stack size for stability
RUST_MIN_STACK=67108864
